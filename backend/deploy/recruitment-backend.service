[Unit]
Description=Recruitment Backend (Gunicorn)
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/recruitment/backend
Environment="PATH=/opt/recruitment/.venv/bin"
ExecStart=/opt/recruitment/.venv/bin/gunicorn -c /opt/recruitment/backend/gunicorn.conf.py wsgi:app
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
